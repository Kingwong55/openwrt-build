# ============================================
# ImmortalWrt x86/64 旁路由定制配置
# 基于 ImmortalWrt 24.10 (openwrt-24.10 分支)
# ============================================

# ---- 目标平台 ----
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

# ---- 固件格式 ----
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_GRUB_EFI_IMAGES=y
# CONFIG_GRUB_IMAGES is not set
CONFIG_TARGET_ROOTFS_PARTSIZE=512
CONFIG_TARGET_KERNEL_PARTSIZE=32

# ---- 固件版本自定义 ----
CONFIG_VERSION_OPT=y
CONFIG_VERSION_NUMBER="24.10 by Kingwong55"
CONFIG_VERSION_MANUFACTURER="Kingwong55 Custom Build"

# ---- 基础系统 ----
CONFIG_PACKAGE_base-files=y
CONFIG_PACKAGE_busybox=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dnsmasq_full_dhcp=y
CONFIG_PACKAGE_dnsmasq_full_ipset=y
# CONFIG_PACKAGE_dnsmasq is not set
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_kmod-nft-tproxy=y

# ---- LuCI 管理界面 ----
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-lib-ipkg=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-mod-network=y
CONFIG_PACKAGE_luci-mod-status=y
CONFIG_PACKAGE_luci-mod-system=y

# ---- 中文语言包 ----
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-opkg-zh-cn=y

# ---- Argon 主题 ----
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-i18n-argon-config-zh-cn=y

# ---- OpenClash (代理) ----
CONFIG_PACKAGE_luci-app-openclash=y

# ---- AdGuard Home (广告拦截) ----
CONFIG_PACKAGE_luci-app-adguardhome=y

# ---- ttyd (Web 终端) ----
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y

# ---- Tailscale (远程组网) ----
CONFIG_PACKAGE_tailscale=y
CONFIG_PACKAGE_tailscaled=y
CONFIG_PACKAGE_luci-app-tailscale=y
CONFIG_PACKAGE_kmod-tun=y

# ---- 网络工具 ----
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_iptables-nft=y
CONFIG_PACKAGE_ipset=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-inet-diag=y
CONFIG_PACKAGE_kmod-ipt-nat=y

# ---- 系统工具 ----
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_coreutils=y
CONFIG_PACKAGE_coreutils-nohup=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_unzip=y
CONFIG_PACKAGE_gzip=y

# ---- OpenClash 依赖 ----
CONFIG_PACKAGE_libcurl=y
CONFIG_PACKAGE_libpthread=y
CONFIG_PACKAGE_libyaml=y
CONFIG_PACKAGE_ruby=y
CONFIG_PACKAGE_ruby-yaml=y

# ---- 精简：移除不需要的包 ----
# WiFi 相关（旁路由不需要）
# CONFIG_PACKAGE_hostapd is not set
# CONFIG_PACKAGE_wpad is not set
# CONFIG_PACKAGE_wpad-basic is not set
# CONFIG_PACKAGE_wpad-basic-openssl is not set
# CONFIG_PACKAGE_kmod-cfg80211 is not set
# CONFIG_PACKAGE_kmod-mac80211 is not set

# USB 相关（不需要）
# CONFIG_PACKAGE_kmod-usb-core is not set
# CONFIG_PACKAGE_kmod-usb2 is not set
# CONFIG_PACKAGE_kmod-usb3 is not set
# CONFIG_PACKAGE_kmod-usb-storage is not set

# PPPoE（主路由负责拨号）
# CONFIG_PACKAGE_ppp is not set
# CONFIG_PACKAGE_ppp-mod-pppoe is not set

# IPv6 完整支持（Clash 节点需要）
CONFIG_PACKAGE_ip6tables-nft=y
CONFIG_PACKAGE_kmod-ip6tables=y
CONFIG_PACKAGE_kmod-nf-nat6=y
CONFIG_PACKAGE_kmod-ipt-nat6=y
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y
CONFIG_PACKAGE_luci-proto-ipv6=y
CONFIG_IPV6=y

# ---- 默认主题设为 Argon ----
CONFIG_LUCI_LANG_zh_Hans=y

# ---- ESXi 虚拟机支持 ----
CONFIG_PACKAGE_open-vm-tools=y
CONFIG_PACKAGE_kmod-vmxnet3=y
CONFIG_PACKAGE_kmod-e1000e=y
CONFIG_PACKAGE_kmod-e1000=y

# ---- EasyTier P2P 组网（开箱即用） ----
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-app-easytier=y
CONFIG_PACKAGE_easytier=y

# ---- 在线固件升级 ----
CONFIG_PACKAGE_luci-app-gpsysupgrade=y
